{
  "openapi": "3.0.3",
  "info": {
    "title": "Counter API",
    "version": "0.1.0",
    "description": "Named counter service with webhooks, audit log, and API key management."
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key token obtained from POST /api/keys"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["error", "code"],
        "properties": {
          "error": { "type": "string" },
          "code": { "type": "string" }
        }
      },
      "Counter": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "integer" }
        }
      },
      "AuditEntry": {
        "type": "object",
        "required": ["id", "actor", "counter_name", "old_value", "new_value", "timestamp"],
        "properties": {
          "id": { "type": "integer" },
          "actor": { "type": "string" },
          "counter_name": { "type": "string" },
          "old_value": { "type": "integer" },
          "new_value": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "ActivityEntry": {
        "type": "object",
        "required": ["id", "action", "timestamp"],
        "properties": {
          "id": { "type": "integer" },
          "action": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "Webhook": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      },
      "WebhookDelivery": {
        "type": "object",
        "required": ["id", "webhook_id", "url", "payload", "status", "attempt_count", "created_at"],
        "properties": {
          "id": { "type": "integer" },
          "webhook_id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "payload": { "type": "object" },
          "status": { "type": "string", "enum": ["pending", "delivered", "failed"] },
          "attempt_count": { "type": "integer" },
          "next_retry_at": { "type": "string", "format": "date-time", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "last_attempted_at": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "ApiKey": {
        "type": "object",
        "required": ["id", "name", "scope", "created_at"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "scope": { "type": "string", "enum": ["read", "write"] },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid authentication token",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Forbidden": {
        "description": "Token lacks required scope",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "TooManyRequests": {
        "description": "Rate limit exceeded",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health check",
        "description": "Returns service uptime, database connectivity status, and version.",
        "security": [],
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["uptime", "db", "version"],
                  "properties": {
                    "uptime": { "type": "number", "description": "Process uptime in seconds" },
                    "db": { "type": "string", "enum": ["ok", "error"] },
                    "version": { "type": "string" }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Database is unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "uptime": { "type": "number" },
                    "db": { "type": "string", "enum": ["error"] },
                    "version": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Prometheus metrics",
        "description": "Returns Prometheus-format metrics for request counts and rate limiter state.",
        "security": [],
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Prometheus text format metrics",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/api/hello": {
      "get": {
        "summary": "Hello world (GET)",
        "security": [],
        "tags": ["Demo"],
        "responses": {
          "200": {
            "description": "Hello response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "method": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Hello world (PUT)",
        "security": [],
        "tags": ["Demo"],
        "responses": {
          "200": {
            "description": "Hello response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "method": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/hello/{name}": {
      "get": {
        "summary": "Personalised hello",
        "security": [],
        "tags": ["Demo"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Personalised greeting",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/counter": {
      "get": {
        "summary": "Get global counter or counters by prefix",
        "tags": ["Counter"],
        "parameters": [
          {
            "name": "prefix",
            "in": "query",
            "required": false,
            "description": "When provided, returns all named counters whose name starts with this prefix",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Counter value(s)",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": ["count"],
                      "properties": {
                        "count": { "type": "integer" }
                      }
                    },
                    {
                      "type": "object",
                      "required": ["prefix", "total", "counters"],
                      "properties": {
                        "prefix": { "type": "string" },
                        "total": { "type": "integer" },
                        "counters": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/Counter" }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "summary": "Increment global counter",
        "tags": ["Counter"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "increment": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 1000000,
                    "description": "Amount to increment by (default: 1)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated counter value",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["count"],
                  "properties": {
                    "count": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/api/counter/{name}": {
      "get": {
        "summary": "Get named counter",
        "description": "Returns the named counter value. Creates the counter with value 0 if it does not exist.",
        "tags": ["Counter"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Named counter",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Counter" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/counter/{name}/increment": {
      "post": {
        "summary": "Increment named counter",
        "tags": ["Counter"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated named counter",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Counter" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/api/counter/{name}/reset": {
      "post": {
        "summary": "Reset named counter to zero",
        "tags": ["Counter"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Counter reset to zero",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Counter" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/api/counter/history": {
      "x-router-priority": "static path takes precedence over /api/counter/{name} at runtime",
      "get": {
        "summary": "Counter activity history",
        "description": "Returns recent counter activity entries (alias of /api/activity).",
        "tags": ["Counter"],
        "responses": {
          "200": {
            "description": "Activity entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["entries"],
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ActivityEntry" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/activity": {
      "get": {
        "summary": "Recent activity log",
        "tags": ["Activity"],
        "responses": {
          "200": {
            "description": "Recent activity entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["entries"],
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ActivityEntry" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/audit": {
      "get": {
        "summary": "Audit log",
        "description": "Returns paginated audit entries recording every counter value change.",
        "tags": ["Audit"],
        "parameters": [
          {
            "name": "counter",
            "in": "query",
            "required": false,
            "description": "Filter by counter name",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of entries to return (default: 50, max: 1000)",
            "schema": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Number of entries to skip for pagination",
            "schema": { "type": "integer", "minimum": 0, "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Audit entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["entries"],
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/AuditEntry" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/webhook/{name}": {
      "post": {
        "summary": "Register webhook for a named counter",
        "tags": ["Webhooks"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Counter name to attach the webhook to",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url"],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Target URL (must use http or https)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook registered",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Webhook" }
              }
            }
          },
          "400": {
            "description": "Invalid URL",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "delete": {
        "summary": "Deregister webhook for a named counter",
        "tags": ["Webhooks"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook removed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["name"],
                  "properties": {
                    "name": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/webhooks": {
      "get": {
        "summary": "List all registered webhooks",
        "tags": ["Webhooks"],
        "responses": {
          "200": {
            "description": "Webhook list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["webhooks"],
                  "properties": {
                    "webhooks": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Webhook" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/webhooks/{id}/deliveries": {
      "get": {
        "summary": "List webhook delivery attempts",
        "tags": ["Webhooks"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Counter name (webhook ID)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Delivery records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["deliveries"],
                  "properties": {
                    "deliveries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/WebhookDelivery" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/keys": {
      "post": {
        "summary": "Create API key",
        "tags": ["API Keys"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "scope"],
                "properties": {
                  "name": { "type": "string", "description": "Human-readable key name (unique)" },
                  "scope": { "type": "string", "enum": ["read", "write"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Key created. The token is shown only once.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiKey" },
                    {
                      "type": "object",
                      "required": ["token"],
                      "properties": {
                        "token": { "type": "string", "description": "Bearer token (shown once)" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": {
            "description": "Key name already exists",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List API keys",
        "tags": ["API Keys"],
        "responses": {
          "200": {
            "description": "API key list (tokens not included)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["keys"],
                  "properties": {
                    "keys": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ApiKey" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/keys/{id}": {
      "delete": {
        "summary": "Delete API key",
        "tags": ["API Keys"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Key deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id"],
                  "properties": {
                    "id": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid id",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/docs": {
      "get": {
        "summary": "OpenAPI 3.0 specification",
        "description": "Returns this OpenAPI document as JSON.",
        "security": [],
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "OpenAPI 3.0 document",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/api/docs/ui": {
      "get": {
        "summary": "Swagger UI",
        "description": "Browser-based API explorer rendering the OpenAPI spec.",
        "security": [],
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Swagger UI HTML page",
            "content": {
              "text/html": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
